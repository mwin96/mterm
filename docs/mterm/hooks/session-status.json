{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-status.sh ready",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-status.sh working",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-status.sh working",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-status.sh done",
        "timeoutSec": 5
      }
    ],
    "notification": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-status.sh notification",
        "timeoutSec": 5
      }
    ]
  }
}
